rules_version = '2';
// ─── Firestore Security Rules for Jarvis Memory ───────────────────────────────
// All access is done via Firebase Admin SDK (server-side only).
// Direct client access is denied for all collections.
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all direct client access — only Admin SDK (server) may read/write
    match /{document=**} {
      allow read, write: if false;
    }
  }
}