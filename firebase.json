{
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.db",
        "*.db-shm",
        "*.db-wal",
        ".env",
        "service-account.json"
      ],
      "predeploy": [
        "npm run build"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
